.cache/
transformers_cache/

# ── Jupyter Notebook Artifacts ───────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Google Colab ─────────────────────────────────────────────
